# ── App ─────────────────────────────────────────────────────────────────────
# Base URL of the running Next.js app (no trailing slash)
APP_BASE_URL=http://localhost:3000

# ── Supabase auth ────────────────────────────────────────────────────────────
# Same values as in apps/web/.env
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Credentials of the user account used to run the evals
EVAL_USER_EMAIL=
EVAL_USER_PASSWORD=

# Optional: paste a raw browser Cookie header value here to skip programmatic
# sign-in (useful when the cookie format changes between @supabase/ssr versions).
# Copy it from DevTools → Network → any /api/* request → Request Headers → Cookie
# EVAL_AUTH_COOKIE=

# ── OpenRouter (used by LLM-as-judge evaluators) ─────────────────────────────
OPENROUTER_API_KEY=

# ── Langfuse ─────────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Defaults to https://cloud.langfuse.com — set only if self-hosting
# LANGFUSE_BASEURL=
