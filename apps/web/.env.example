# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direct connection (used by LangGraph checkpointer — must be the direct URL, not the pooler)
# In Supabase: Settings → Database → Connection string → URI (mode: Session/Direct, not Transaction)
DATABASE_URL=

# OpenRouter
OPENROUTER_API_KEY=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=

# OAuth encryption
OAUTH_ENCRYPTION_KEY=

# Bash tool (optional, high-risk)
# Set to "true" to enable execution of bash commands on the server host.
# Leave unset or set to any other value to disable (fail-closed default).
BASH_TOOL_ENABLED=
# Absolute path to use as working directory for bash commands.
# Defaults to process.cwd() if unset or invalid.
BASH_TOOL_CWD=

# Next.js (optional)
NEXT_ALLOWED_DEV_ORIGINS=
